# ── Pinocchio Transcription Service — Environment Template ──
# Copy this file to .env and replace the placeholders with your real values.
# IMPORTANT: Do NOT commit your real tokens to source control.
#
# TOKEN ROTATION: If this repo previously had tokens in git history,
# rotate them immediately:
#   - HuggingFace: https://huggingface.co/settings/tokens
#   - Runpod:      https://www.runpod.io/console/user/settings

# ── HuggingFace (pyannote diarization model access) ──
HUGGINGFACE_HUB_TOKEN=your_new_hf_token_here
PYANNOTE_AUTH_TOKEN=your_new_hf_token_here
HF_TOKEN=your_new_hf_token_here
# Legacy compatibility only (optional)
use_auth_token=your_new_hf_token_here

# ── Local data directories ──
AUDIO_DIR=./data/audio
ORIGINALS_DIR=./data/originals
TRANSCRIPT_DIR=./data/transcripts
NARRATIVE_DIR=./data/transcripts_narrative
REFERENCE_DIR=./data/transcripts_by_audio
QUEUE_PATH=./data/queue.json

# ── RunPod Serverless ──
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_API_URL=https://api.runpod.ai/v2
RUNPOD_ENDPOINT_ID=your_endpoint_id_here

# ── Anthropic Claude (reconciliation + analysis) ──
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Qdrant (vector search) ──
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Docker Hub (CI/CD) ──
DOCKER_USERNAME=your_dockerhub_username
DOCKER_IMAGE=your_dockerhub_username/pinocchio-transcription

# ── Logging ──
LOG_LEVEL=INFO

# ── CORS (comma-separated origins) ──
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
