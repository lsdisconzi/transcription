# HuggingFace / Pyannote
# Get your token at: https://huggingface.co/settings/tokens
PYANNOTE_AUTH_TOKEN=<your_huggingface_token>
HF_TOKEN=<your_huggingface_token>
HUGGINGFACE_HUB_TOKEN=<your_huggingface_token>

# Anthropic (Claude) - optional, routes through DeepSeek endpoint by default
ANTHROPIC_API_KEY=<optional_anthropic_api_key>
ANTHROPIC_MODEL=deepseek-v4-pro
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# DeepSeek
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=<your_deepseek_api_key>
DEEPSEEK_ANALYZER_MODEL=deepseek-v4-flash
DEEPSEEK_RECONCILER_MODEL=deepseek-v4-pro

# Qdrant Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=<your_qdrant_api_key>

# RunPod Serverless
# Get your key at: https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=<your_runpod_api_key>
RUNPOD_ENDPOINT_ID=<your_endpoint_id>

# Data directories
AUDIO_DIR=./data/audio
ORIGINALS_DIR=./data/originals
TRANSCRIPT_DIR=./data/transcripts
REFERENCE_DIR=./data/transcripts_by_audio
NARRATIVE_DIR=./data/transcripts_narrative
PROJECTS_DIR=./data/projects

# Validate-and-refine
ENABLE_ACOUSTIC_PROBES=true

# Model preloading (set to true to preload models at startup)
PRELOAD_MODELS=false
