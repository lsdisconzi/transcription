# ── Pinocchio Transcription Service — Environment Template ──
# Copy this file to .env and replace the placeholders with your real values.
# IMPORTANT: Do NOT commit your real tokens to source control.
#
# TOKEN ROTATION: If this repo previously had tokens in git history,
# rotate them immediately:
#   - HuggingFace: https://huggingface.co/settings/tokens
#   - Runpod:      https://www.runpod.io/console/user/settings

# ── HuggingFace (pyannote diarization model access) ──
# All four keys resolve to the same token — the service picks the first non-empty
# value in the order: PYANNOTE_AUTH_TOKEN → HF_TOKEN → HUGGINGFACE_HUB_TOKEN → use_auth_token
PYANNOTE_AUTH_TOKEN=your_hf_token_here
HF_TOKEN=your_hf_token_here
HUGGINGFACE_HUB_TOKEN=your_hf_token_here
use_auth_token=your_hf_token_here

# ── Local data directories ──
# Defaults below match the Docker volume mounts; override only if running bare-metal.
AUDIO_DIR=./data/audio
ORIGINALS_DIR=./data/originals
TRANSCRIPT_DIR=./data/transcripts
NARRATIVE_DIR=./data/transcripts_narrative
REFERENCE_DIR=./data/transcripts_by_audio

# ── RunPod Serverless ──
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_ENDPOINT_ID=your_endpoint_id_here
RUNPOD_API_URL=https://api.runpod.ai/v2

# ── AI providers (at least one required for transcript analysis / reconciliation) ──
# Anthropic Claude — primary provider
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# DeepSeek — alternative provider (used when ANTHROPIC_API_KEY is not set)
DEEPSEEK_API_KEY=
DEEPSEEK_RECONCILER_MODEL=deepseek-reasoner

# ── Qdrant (vector search — optional) ──
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Logging ──
LOG_LEVEL=INFO

# ── CORS (comma-separated allowed origins) ──
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
