  "segments": [
    {
      "speaker": "SPEAKER_00",
      "start": 0.8072187500000001,
      "end": 7.92846875,
      "text": " Entonces me han enviado una carta explicándome lo que sucedió, pero no hay una asignatura ni un timbre de la lata.",
      "id": "0"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 9.31221875,
      "end": 14.77971875,
      "text": " Creo que se queda un poco complejo esto. Mira, me está pasando un documento.",
      "id": "1"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 18.39096875,
      "end": 19.38659375,
      "text": " ¿Por qué tú no quieres firmar?",
      "id": "2"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 23.04846875,
      "end": 26.997218750000002,
      "text": " Estoy haciendo una pregunta. ¿Quién escribió la carta?",
      "id": "3"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 30.32159375,
      "end": 32.07659375,
      "text": " Estoy pensando en la pregunta.",
      "id": "4"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 32.92034375,
      "end": 34.30409375,
      "text": " Yo estoy haciendo una pregunta.",
      "id": "5"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 35.56971875,
      "end": 40.547843750000006,
      "text": " Pero tú me pasaste una carta sin firmar. Tú me pasaste una carta sin firmar.",
      "id": "6"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 42.10034375,
      "end": 51.297218750000006,
      "text": " Tu nombre, Antonella. Antonella Saragallo. Ya, mira, tú me pasó un documento que yo estoy esperando a ocho más horas.",
      "id": "7"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 52.174718750000004,
      "end": 53.204093750000006,
      "text": " sin una firma.",
      "id": "8"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 81.01409375,
      "end": 82.93784375,
      "text": " ¿Un documento no necesita ya una firma?",
      "id": "9"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 86.44784375,
      "end": 89.60346875,
      "text": " Nadie responde.",
      "id": "10"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 101.48346875,
      "end": 104.68971875000001,
      "text": " porque entienden que es abuso de autoridad lo que están haciendo.",
      "id": "11"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 106.96784375,
      "end": 111.13596875,
      "text": " ¡Qué discaso!",
      "id": "12"
    },
    {
      "speaker": "SPEAKER_01",
      "start": 109.26284375,
      "end": 109.83659375,
      "text": "",
      "id": "13"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 122.35784375,
      "end": 127.03221875000001,
      "text": " Gracias por ver el vídeo, ¡suscríbete y dale a like!",
      "id": "14"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 132.83721875,
      "end": 135.26721875,
      "text": " Gracias.",
      "id": "15"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 136.21221875,
      "end": 137.71409375000002,
      "text": " Muchas gracias.",
      "id": "16"
    },
    {
      "speaker": "SPEAKER_00",
      "start": 138.47346875,
      "end": 141.00471875,
      "text": " Subtítulos por la comunidad de Amara.org",
