{
  "title": "aeropuerto_STG_1",
  "subtitle": "1st interaction - Pilots",
  "filename": "aeropuerto_STG_1",
  "recordingdatetime": "2024-07-05T12:56:00",
  "location": "Arturo Merino Benítez International Airport, Santiago, Chile",
  "content": [
    {
      "speaker": "Leandro",
      "start": 16,
      "end": 18.03,
      "text": "opa, tudo bem? Espanhol certo?",
      "id": "0"
    },
    {
      "speaker": "Latam Pilot Ruiz",
      "start": 18.04,
      "end": 19,
      "text": "Portugues mesmo.",
      "id": "1"
    },
    {
      "speaker": "Leandro",
      "start": 19.2,
      "end": 22.1,
      "text": " Voce sabe qual e esse vou que esta chegando ae agora?",
      "id": "2"
    },
    {
      "speaker": "Latam Pilot Ruiz",
      "start": 22.7,
      "end": 27.3,
      "text": "Da onde que ele chegou eu nao sei, mas e o que vamos a Brasilia.",
      "id": "3"
    },
    {
      "speaker": "Leandro",
      "start": 27.31,
      "end": 38.19,
      "text": " Porque está atrasado. Y porque el vuelo de brasil también va a estar atrasado. Y nadie nos avisa.",
      "id": "4"
    },
    {
      "speaker": "Latam Piloto Ruiz",
      "start": 39.3,
      "end": 44.7,
      "text": "Cara, voce tem 45 minutos para decolar, vai dar mais ou menos no horario.",
      "id": "5"
    },
    {
      "speaker": "Leandro",
      "start": 44.85,
      "end": 46.3,
      "text": " Voce acha?",
      "id": "6"
    },
    {
      "speaker": "Latam Pilot Ruiz?",
      "start": 46.25,
      "end": 51,
      "text": "A gente ta no horario ainda.",
      "id": "7"
    },
    {
      "speaker": "Leandro",
      "start": 51.1,
      "end": 59.9,
      "text": "E que a historia com a Latam ja ta longa, ta cansativa ja. Valeu.",
      "id": "8"
    }
  ],
